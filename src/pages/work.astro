```astro
---
import { getCollection } from 'astro:content';
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = (await getCollection('work')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
	title="QA Projects | Elijah Alford"
	description="Explore Elijah Alford's software quality assurance and testing projects."
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">

			<Hero
				title="QA Projects"
				tagline="Explore my software testing projects, automation frameworks, and quality assurance experience using modern testing tools and methodologies."
				align="start"
			/>

			<Grid variant="offset">
				{
					projects.map((project) => (
						<li>
							<PortfolioPreview project={project} />
						</li>
					))
				}
			</Grid>

		</main>

		<ContactCTA />

	</div>
</BaseLayout>
```
