```astro

---
import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
	title="About | Elijah Alford" 
	description="About Elijah Alford, QA Engineer specializing in software quality, testing, and software development."
>
	<div class="stack gap-20">
		<main class="wrapper about">

			<Hero
				title="About"
				tagline="Thanks for stopping by. Learn more about my background, experience, and passion for software quality and development."
			>
				<img
					width="1553"
					height="873"
					src="/assets/at-work.jpg"
					alt="Elijah Alford working as a QA Engineer"
				/>
			</Hero>


			<section>
				<h2 class="section-title">Background</h2>

				<div class="content">
					<p>
						My name is Elijah Alford, and I am a QA Engineer and software developer
						based in Greensboro, North Carolina. I specialize in software testing,
						quality assurance, and building reliable, user-focused applications.
					</p>

					<p>
						I have experience designing test plans, writing test cases, performing
						functional and regression testing, API testing, and improving software
						quality through detailed analysis and problem solving.
					</p>

					<p>
						My development background allows me to collaborate effectively with
						engineering teams while understanding both the user experience and the
						technical side of software applications.
					</p>
				</div>
			</section>


			<section>
				<h2 class="section-title">Education</h2>

				<div class="content">
					<p>
						Bachelor of Science in Computer Science with a focus on software
						development, quality assurance, testing methodologies, and modern
						software engineering practices.
					</p>
				</div>
			</section>


			<section>
				<h2 class="section-title">Technical Skills</h2>

				<div class="content">
					<p>
						<strong>Frontend:</strong>
						HTML, CSS, JavaScript, React
					</p>

					<p>
						<strong>Backend:</strong>
						Java, Node.js, FastAPI, PHP (Laravel)
					</p>

					<p>
						<strong>Databases:</strong>
						PostgreSQL, SQL, Neon
					</p>

					<p>
						<strong>Tools:</strong>
						Git, Postman, VS Code, IntelliJ IDEA, Google Cloud Platform
					</p>

					<p>
						<strong>Concepts:</strong>
						Responsive Design, UX/UI Principles, MVC Architecture, REST APIs
					</p>

					<p>
						<strong>Quality Assurance:</strong>
						Manual Testing, Functional Testing, Regression Testing,
						Test Case Development, Bug Reporting, API Testing,
						Automation Testing, SDLC, STLC, Agile Methodologies
					</p>
				</div>
			</section>


			<section class="contact">
				<h2 class="section-title">Contact Me</h2>

				<div class="content">
					<p>
						Email:
						<a href="mailto:jaleelalford40@gmail.com">
							jaleelalford40@gmail.com
						</a>
					</p>

					<p>
						Phone: 910-286-1661
					</p>

					<p>
						LinkedIn:
						<a href="https://www.linkedin.com/in/elijah-alford-594579260/">
							linkedin.com/in/elijah-alford-594579260
						</a>
					</p>

					<p>
						GitHub:
						<a href="https://github.com/ElijahAlford765">
							github.com/ElijahAlford765
						</a>
					</p>
				</div>
			</section>


			<footer>
				<p>
					© 2026 Elijah Alford |
					<a href="https://github.com/ElijahAlford765">
						GitHub
					</a>
				</p>
			</footer>

		</main>

		<ContactCTA />

	</div>
</BaseLayout>
```


<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
